generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// PUBLIC SCHEMA — Shared across all tenants
// ============================================

model Tenant {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @db.VarChar(200)
  slug      String   @unique @db.VarChar(100)
  subdomain String   @unique @db.VarChar(100)
  status    String   @default("pending_verification") @db.VarChar(30)
  country   String   @default("AR") @db.VarChar(2)
  plan      String   @default("free") @db.VarChar(20)

  trialEndsAt DateTime? @map("trial_ends_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  users         UserTenant[]
  subscription  Subscription?

  @@map("tenants")
}

model User {
  id            String   @id @default(uuid()) @db.Uuid
  email         String   @unique @db.VarChar(255)
  passwordHash  String   @map("password_hash") @db.VarChar(255)
  fullName      String   @map("full_name") @db.VarChar(200)
  phone         String?  @db.VarChar(20)
  status        String   @default("pending_verification") @db.VarChar(30)
  emailVerified Boolean  @default(false) @map("email_verified")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenants            UserTenant[]
  emailVerifications EmailVerification[]
  refreshTokens      RefreshToken[]

  @@map("users")
}

model UserTenant {
  id       String @id @default(uuid()) @db.Uuid
  userId   String @map("user_id") @db.Uuid
  tenantId String @map("tenant_id") @db.Uuid
  role     String @db.VarChar(30)

  createdAt DateTime @default(now()) @map("created_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId])
  @@map("user_tenants")
}

model Subscription {
  id              String   @id @default(uuid()) @db.Uuid
  tenantId        String   @unique @map("tenant_id") @db.Uuid
  plan            String   @db.VarChar(20)
  status          String   @default("trialing") @db.VarChar(30)
  billingCycle    String?  @map("billing_cycle") @db.VarChar(10)
  stripeCustomerId    String? @map("stripe_customer_id") @db.VarChar(255)
  stripeSubscriptionId String? @map("stripe_subscription_id") @db.VarChar(255)

  currentPeriodStart DateTime? @map("current_period_start")
  currentPeriodEnd   DateTime? @map("current_period_end")
  cancelledAt        DateTime? @map("cancelled_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

// ============================================
// GLOBAL AUTH TABLES — No RLS (operate before tenant context)
// ============================================

model EmailVerification {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  token     String   @unique @db.VarChar(255)
  expiresAt DateTime @map("expires_at")
  usedAt    DateTime? @map("used_at")

  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("email_verifications")
}

model RefreshToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  tokenHash String   @unique @map("token_hash") @db.VarChar(255)
  familyId  String   @map("family_id") @db.Uuid
  expiresAt DateTime @map("expires_at")
  revokedAt DateTime? @map("revoked_at")

  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([familyId])
  @@map("refresh_tokens")
}

model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  action    String   @db.VarChar(100)
  resource  String   @db.VarChar(100)
  resourceId String? @map("resource_id") @db.VarChar(100)
  details   Json?
  ip        String?  @db.VarChar(45)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([tenantId, createdAt])
  @@index([userId])
  @@map("audit_logs")
}

// ============================================
// TENANT-SCOPED BUSINESS MODELS — RLS enforced
// ============================================

model Client {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  name      String   @db.VarChar(255)
  email     String?  @db.VarChar(255)
  phone     String?  @db.VarChar(50)
  address   String?  @db.Text
  status    String   @default("active") @db.VarChar(20)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  vehicles   Vehicle[]
  workOrders WorkOrder[]

  @@unique([tenantId, email])
  @@unique([tenantId, phone])
  @@index([tenantId, name])
  @@map("clients")
}

model Vehicle {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  clientId  String   @map("client_id") @db.Uuid
  make      String   @db.VarChar(100)
  model     String   @db.VarChar(100)
  year      Int?
  plate     String   @db.VarChar(20)
  vin       String?  @db.VarChar(17)
  color     String?  @db.VarChar(50)
  fuelType  String?  @map("fuel_type") @db.VarChar(30)
  mileage   Int?     @default(0)
  notes     String?  @db.Text
  status    String   @default("active") @db.VarChar(20)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  client     Client      @relation(fields: [clientId], references: [id], onDelete: Restrict)
  workOrders WorkOrder[]

  @@unique([tenantId, plate])
  @@unique([tenantId, vin])
  @@index([tenantId, make, model])
  @@index([clientId])
  @@map("vehicles")
}

model Mechanic {
  id              String   @id @default(uuid()) @db.Uuid
  tenantId        String   @map("tenant_id") @db.Uuid
  name            String   @db.VarChar(255)
  email           String?  @db.VarChar(255)
  phone           String?  @db.VarChar(20)
  specializations String[] @db.VarChar(100)
  hireDate        DateTime? @map("hire_date")
  hourlyRate      Decimal? @map("hourly_rate") @db.Decimal(10, 2)
  notes           String?  @db.Text
  status          String   @default("active") @db.VarChar(20)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  workOrders WorkOrderMechanic[]
  checklistExecutions ChecklistExecution[]

  @@unique([tenantId, email])
  @@unique([tenantId, phone])
  @@index([tenantId, name])
  @@map("mechanics")
}

model SparePart {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  code         String   @db.VarChar(50)
  name         String   @db.VarChar(255)
  description  String?  @db.Text
  category     String?  @db.VarChar(100)
  unit         String   @default("unit") @db.VarChar(30)
  currentStock Int      @default(0) @map("current_stock")
  minStock     Int      @default(0) @map("min_stock")
  maxStock     Int      @default(0) @map("max_stock")
  unitCost     Decimal? @map("unit_cost") @db.Decimal(10, 2)
  sellingPrice Decimal? @map("selling_price") @db.Decimal(10, 2)
  supplier     String?  @db.VarChar(200)
  notes        String?  @db.Text
  status       String   @default("active") @db.VarChar(20)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  workOrders WorkOrderSparePart[]

  @@unique([tenantId, code])
  @@index([tenantId, name])
  @@index([tenantId, category])
  @@map("spare_parts")
}

model WorkOrder {
  id            String    @id @default(uuid()) @db.Uuid
  tenantId      String    @map("tenant_id") @db.Uuid
  vehicleId     String    @map("vehicle_id") @db.Uuid
  clientId      String    @map("client_id") @db.Uuid
  milestone     String    @default("created") @db.VarChar(30)
  priority      String    @default("normal") @db.VarChar(20)
  scheduledAt   DateTime? @map("scheduled_at")
  startedAt     DateTime? @map("started_at")
  completedAt   DateTime? @map("completed_at")
  description   String    @db.Text
  clientNotes   String?   @map("client_notes") @db.Text
  internalNotes String?   @map("internal_notes") @db.Text
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  vehicle      Vehicle               @relation(fields: [vehicleId], references: [id], onDelete: Restrict)
  client       Client                @relation(fields: [clientId], references: [id], onDelete: Restrict)
  mechanics    WorkOrderMechanic[]
  spareParts   WorkOrderSparePart[]
  cost         WorkOrderCost?
  checklists   ChecklistExecution[]

  @@index([tenantId, milestone])
  @@index([tenantId, vehicleId])
  @@index([tenantId, clientId])
  @@map("work_orders")
}

model WorkOrderMechanic {
  id          String  @id @default(uuid()) @db.Uuid
  tenantId    String  @map("tenant_id") @db.Uuid
  workOrderId String  @map("work_order_id") @db.Uuid
  mechanicId  String  @map("mechanic_id") @db.Uuid
  isPrimary   Boolean @default(false) @map("is_primary")

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  mechanic  Mechanic  @relation(fields: [mechanicId], references: [id], onDelete: Restrict)

  @@unique([workOrderId, mechanicId])
  @@index([workOrderId])
  @@index([mechanicId])
  @@map("work_order_mechanics")
}

model WorkOrderSparePart {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  workOrderId String   @map("work_order_id") @db.Uuid
  sparePartId String   @map("spare_part_id") @db.Uuid
  quantity    Int
  unitPrice   Decimal  @map("unit_price") @db.Decimal(10, 2)
  totalPrice  Decimal  @map("total_price") @db.Decimal(10, 2)
  status      String   @default("reserved") @db.VarChar(20)
  reservedAt  DateTime @default(now()) @map("reserved_at")
  consumedAt  DateTime? @map("consumed_at")
  returnedAt  DateTime? @map("returned_at")

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  sparePart SparePart @relation(fields: [sparePartId], references: [id], onDelete: Restrict)

  @@index([workOrderId])
  @@index([sparePartId])
  @@map("work_order_spare_parts")
}

model WorkOrderCost {
  id              String    @id @default(uuid()) @db.Uuid
  workOrderId     String    @unique @map("work_order_id") @db.Uuid
  laborCost       Decimal?  @map("labor_cost") @db.Decimal(10, 2)
  partsCost       Decimal?  @map("parts_cost") @db.Decimal(10, 2)
  subtotal        Decimal?  @db.Decimal(10, 2)
  taxRate         Decimal?  @default(0.21) @map("tax_rate") @db.Decimal(5, 4)
  taxAmount       Decimal?  @map("tax_amount") @db.Decimal(10, 2)
  discountPercent Decimal?  @map("discount_percent") @db.Decimal(5, 2)
  discountAmount  Decimal?  @map("discount_amount") @db.Decimal(10, 2)
  total           Decimal?  @db.Decimal(10, 2)
  calculatedAt    DateTime? @map("calculated_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)

  @@map("work_order_costs")
}

model ChecklistTemplate {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  name        String   @db.VarChar(255)
  description String?  @db.Text
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  sections   ChecklistSection[]
  executions ChecklistExecution[]

  @@index([tenantId, isActive])
  @@map("checklist_templates")
}

model ChecklistSection {
  id         String  @id @default(uuid()) @db.Uuid
  tenantId   String  @map("tenant_id") @db.Uuid
  templateId String  @map("template_id") @db.Uuid
  name       String  @db.VarChar(255)
  order      Int
  isRequired Boolean @default(true) @map("is_required")

  template  ChecklistTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  questions ChecklistQuestion[]

  @@index([templateId, order])
  @@map("checklist_sections")
}

model ChecklistQuestion {
  id         String  @id @default(uuid()) @db.Uuid
  tenantId   String  @map("tenant_id") @db.Uuid
  sectionId  String  @map("section_id") @db.Uuid
  text       String  @db.Text
  type       String  @db.VarChar(30)
  options    Json?
  isRequired Boolean @default(true) @map("is_required")
  order      Int
  weight     Int     @default(1)

  section ChecklistSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  answers ChecklistAnswer[]

  @@index([sectionId, order])
  @@map("checklist_questions")
}

model ChecklistExecution {
  id          String    @id @default(uuid()) @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  templateId  String    @map("template_id") @db.Uuid
  workOrderId String    @map("work_order_id") @db.Uuid
  mechanicId  String    @map("mechanic_id") @db.Uuid
  status      String    @default("pending") @db.VarChar(20)
  score       Decimal?  @db.Decimal(5, 2)
  passed      Boolean?
  startedAt   DateTime? @map("started_at")
  completedAt DateTime? @map("completed_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  template  ChecklistTemplate @relation(fields: [templateId], references: [id])
  workOrder WorkOrder         @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  mechanic  Mechanic          @relation(fields: [mechanicId], references: [id])
  answers   ChecklistAnswer[]

  @@index([workOrderId, status])
  @@index([tenantId, templateId])
  @@map("checklist_executions")
}

model ChecklistAnswer {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  executionId String  @map("execution_id") @db.Uuid
  questionId String   @map("question_id") @db.Uuid
  answer     String   @db.Text
  score      Int?
  answeredAt DateTime @default(now()) @map("answered_at")

  execution ChecklistExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)
  question  ChecklistQuestion  @relation(fields: [questionId], references: [id])

  @@unique([executionId, questionId])
  @@map("checklist_answers")
}
